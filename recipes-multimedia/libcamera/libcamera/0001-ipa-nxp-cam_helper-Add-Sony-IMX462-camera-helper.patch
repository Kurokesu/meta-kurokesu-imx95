From 42b113e9cddc19b60045e8bc8ed38c824de9914a Mon Sep 17 00:00:00 2001
From: Danius Kalvaitis <danius@kurokesu.com>
Date: Mon, 20 Jul 2026 10:27:10 +0300
Subject: [PATCH 1/3] ipa: nxp: cam_helper: Add Sony IMX462 camera helper

IMX462 is an IMX290 derivative and reuses its gain model and black
level. Register a CameraHelper so the NEO IPA can drive it.

Mono IMX462LLR reports the same "imx462" name and shares this helper.

Upstream-Status: Inappropriate [NXP libcamera fork specific]
---
 .../nxp/cam_helper/camera_helper_imx462.cpp   | 37 +++++++++++++++++++
 src/ipa/nxp/cam_helper/meson.build            |  1 +
 2 files changed, 38 insertions(+)
 create mode 100644 src/ipa/nxp/cam_helper/camera_helper_imx462.cpp

diff --git a/src/ipa/nxp/cam_helper/camera_helper_imx462.cpp b/src/ipa/nxp/cam_helper/camera_helper_imx462.cpp
new file mode 100644
index 0000000..66127ea
--- /dev/null
+++ b/src/ipa/nxp/cam_helper/camera_helper_imx462.cpp
@@ -0,0 +1,37 @@
+/* SPDX-License-Identifier: LGPL-2.1-or-later */
+/*
+ * camera_helper_imx462.cpp
+ * Helper class that performs sensor-specific parameter computations
+ * for Sony IMX462 sensor
+ */
+
+#include <cmath>
+
+#include <libcamera/base/log.h>
+
+#include "camera_helper.h"
+
+namespace libcamera {
+
+LOG_DECLARE_CATEGORY(NxpCameraHelper)
+
+namespace nxp {
+
+class CameraHelperImx462 : public CameraHelper
+{
+public:
+	CameraHelperImx462()
+	{
+		/* 0xF0 at 12bits. */
+		blackLevel_ = 3840;
+
+		/* IMX290 gain model, 0.3 dB per code (see libipa expGainDb). */
+		gain_ = AnalogueGainExp{ 1.0, std::log2(10.0) * 0.3 / 20 };
+	}
+};
+
+REGISTER_CAMERA_HELPER("imx462", CameraHelperImx462)
+
+} /* namespace nxp */
+
+} /* namespace libcamera */
diff --git a/src/ipa/nxp/cam_helper/meson.build b/src/ipa/nxp/cam_helper/meson.build
index 9a1bcd3..8c52e6a 100644
--- a/src/ipa/nxp/cam_helper/meson.build
+++ b/src/ipa/nxp/cam_helper/meson.build
@@ -6,6 +6,7 @@ nxp_ipa_cam_helper_headers = files([
 
 nxp_ipa_cam_helper_sources = files([
     'camera_helper.cpp',
+    'camera_helper_imx462.cpp',
     'camera_helper_mx95mbcam.cpp',
     'camera_helper_os08a20.cpp',
     'camera_helper_ov5640.cpp',
-- 
