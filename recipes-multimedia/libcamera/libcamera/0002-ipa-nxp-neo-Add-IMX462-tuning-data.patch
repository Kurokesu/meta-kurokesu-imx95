+%YAML 1.1
+---
+# Colour algorithms (Awb, Ccm) are omitted, the mono pipeline needs none.
+version: 1
+algorithms:
+  - BlackLevelCorrection:
+      # Black level 0x3C at 10-bit, as 16-bit offsets: 0x3C << 6 = 3840.
+      reference-bitdepth: 10
+      R: 3840
+      Gr: 3840
+      Gb: 3840
+      B: 3840
